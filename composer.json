{
    "name": "demo/order-processing",
    "description": "Deliberately flawed PHP app for a static-analysis & refactoring talk. NOT production code.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.10",
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^9.6",
        "rector/rector": "^1.2"
    },
    "autoload": {
        "psr-4": { "Demo\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": {
            "Demo\\Rector\\": "ai/rules/",
            "Demo\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": { "php": "8.3.0" },
        "sort-packages": true
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml src",
        "lint:fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "refactor:dry": "rector process --dry-run",
        "refactor": "rector process",
        "test": "phpunit"
    }
}
